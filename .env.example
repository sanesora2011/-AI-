# ═══════════════════════════════════════
# AI 每日简报 — 环境变量配置
# ═══════════════════════════════════════

# 网易 163 邮箱 SMTP 配置
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=你的163邮箱地址@163.com
SMTP_PASS=你的SMTP授权码（在163邮箱设置→POP3/SMTP中获取，16位字母）

# 接收邮箱（默认等于 SMTP_USER）
TO_EMAIL=14795010951@163.com

# DeepSeek API 配置（用于生成摘要）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx
LLM_MODEL=deepseek-chat

# 定时设置（cron 表达式，默认每天上午 9:00）
CRON_SCHEDULE=0 9 * * *

# 数据文件路径（记录已发送的文章ID，用于去重）
STATE_FILE=./data/state.json
